{
  "name": "shopping-list",
  "private": true,
  "version": "0.10.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "node server/index.mjs",
    "prepare": "git config core.hooksPath .githooks",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:unit && npm run test:storybook",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:storybook": "vitest run --project storybook",
    "test:all": "npm run test",
    "version:auto": "node scripts/bump-version.mjs auto",
    "version:prepush": "node scripts/bump-version.mjs prepush",
    "version:major": "node scripts/bump-version.mjs major",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:patch": "node scripts/bump-version.mjs patch",
    "push": "node scripts/push-with-version.mjs",
    "storybook": "storybook dev -p 7007",
    "build-storybook": "storybook build",
    "typecheck": "tsc -b --pretty false",
    "build": "tsc -b && vite build",
    "lighthouse": "npm run build && node scripts/lighthouse-audit.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-storybook": "10.3.5",
    "globals": "^17.5.0",
    "lighthouse": "^13.1.0",
    "playwright": "^1.59.1",
    "sass": "^1.83.4",
    "storybook": "^10.3.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
